        <referenceContainer name="content">
            <block class="ETechFlow\\PageSpeedOptimizerPremium\\Block\\Adminhtml\\UpdateNotice"
                   name="etechflow_psop_update_notice"
                   template="ETechFlow_PageSpeedOptimizerPremium::update-notice.phtml"
                   cacheable="false"
